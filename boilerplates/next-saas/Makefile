.PHONY: dev build start test test-coverage e2e lint format typecheck audit metrics

dev:
	npm run dev

build:
	npm run build

start:
	npm run start

test:
	npm run test

test-coverage:
	npm run test:coverage

e2e:
	npm run e2e

lint:
	npm run lint

format:
	npm run format

typecheck:
	npm run typecheck

audit:
	npm audit --audit-level=high

metrics:
	npm run test:coverage && npm run metrics
