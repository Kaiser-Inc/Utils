meta {
  name: Refresh Token
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/auth/refresh
  body: none
  auth: none
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("accessToken", res.body.accessToken);
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
}
