{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "lib": ["ES2022"],
    "target": "ES2022",
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*", "global.css"],
  "exclude": ["node_modules", "scripts"]
}
