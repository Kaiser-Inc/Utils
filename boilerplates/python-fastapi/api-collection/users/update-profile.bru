meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/users/me
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "username": "alice_updated"
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
}
