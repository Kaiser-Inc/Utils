# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any non-managed temp files in tests).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# RSpec
.rspec_status
/coverage

# Swagger — gerado via `make docs`, não versionado (exceto o .keep)
/swagger/v1/swagger.yaml

# Editors
.idea/
.vscode/
*.swp
*.swo
