# Node — pnpm-lock.yaml é canônico; package-lock.json nunca commitado
boilerplates/*/package-lock.json
boilerplates/*/yarn.lock
boilerplates/node-fastify/node_modules/
boilerplates/node-fastify/dist/

# Coverage — gerado por testes, nunca commitado
boilerplates/*/coverage/
boilerplates/*/coverage.json
boilerplates/*/coverage.xml
boilerplates/*/.coverage
boilerplates/*/htmlcov/
boilerplates/*/tsconfig.tsbuildinfo

# Python
boilerplates/python-fastapi/__pycache__/
boilerplates/python-fastapi/**/__pycache__/
boilerplates/python-fastapi/*.pyc
boilerplates/python-fastapi/.pytest_cache/
boilerplates/python-fastapi/.ruff_cache/
boilerplates/python-fastapi/htmlcov/
boilerplates/python-fastapi/.coverage

# Ruby
boilerplates/ruby-on-rails/log/
boilerplates/ruby-on-rails/tmp/
boilerplates/ruby-on-rails/storage/
boilerplates/ruby-on-rails/vendor/bundle/
boilerplates/ruby-on-rails/.bundle/

# Metrics — gerado por make metrics, nunca commitado
boilerplates/python-fastapi/metrics/
boilerplates/node-fastify/metrics/
boilerplates/ruby-on-rails/metrics/

# Environment files
.env
**/.env
**/.env.bak

# Knowledge graph output (graphify)
graphify-out/

# Claude Code
.claude

